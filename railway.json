{
  "$schema": "https://railway.json.sh",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyMaxRetries": 5,
    "healthcheck": {
      "command": "node -e \"require('http').get('http://localhost:3000', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})\"",
      "interval": 30,
      "timeout": 5,
      "retries": 3
    }
  },
  "variables": {
    "PORT": "3000"
  }
}
